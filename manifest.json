{
    "manifest_version": 3,
    "name": "2FA Authenticator",
    "version": "1.3.0",
    "description": "Tạo mã xác thực 2FA (TOTP) cho các dịch vụ",
    "icons": {
        "16": "icons/logo.png",
        "48": "icons/logo.png",
        "128": "icons/logo.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/logo.png",
            "48": "icons/logo.png"
        },
        "default_title": "2FA Authenticator"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "clipboardWrite",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ]
}